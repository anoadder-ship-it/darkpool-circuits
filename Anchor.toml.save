[toolchain]
anchor_version = "1.1.2"
package_manager = "yarn"


[features]
resolution = true
skip-lint = false

[programs.devnet]
chip_darkpool = "6xLjbo4yfc5j2CMu69DkycTJrGZttHzeqieXf2NPvu8o"
medical_darkpool = "CZQBaJFJnGA2pyEnrfxCmsUewcHJLDGHgzrcVjomzDD4"
solana_darkpool = "h6zsnHt28NpeS94Ek3fQP1YEiu1WrpGT2pKynWZzKVX"
supply_chain_darkpool = "3HQHpSBSgYkx81E25bSJZVz4mGoW6nQFJWDtZL9fmMR4"

[programs.localnet]
chip_darkpool = "6xLjbo4yfc5j2CMu69DkycTJrGZttHzeqieXf2NPvu8o"
medical_darkpool = "CZQBaJFJnGA2pyEnrfxCmsUewcHJLDGHgzrcVjomzDD4"
